<Window x:Class="YueXinMiaoPet.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="月薪喵设置"
        Icon="pack://siteoforigin:,,,/Assets/Icons/app.ico"
        Width="820"
        Height="780"
        MinWidth="760"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="刷新调试信息" Margin="0,0,8,0" Click="OnRefreshDebugClick" />
            <Button Content="重新扫描 GIF" Margin="0,0,8,0" Click="OnRescanClick" />
            <Button Content="恢复默认" Margin="0,0,8,0" Click="OnRestoreDefaultsClick" />
            <Button Content="保存设置" Width="90" Margin="0,0,8,0" Click="OnSaveClick" />
            <Button Content="取消" Width="72" Click="OnCancelClick" />
        </StackPanel>

        <TabControl>
            <TabItem Header="基础设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <GroupBox Header="GIF 资源来源" Margin="0,0,0,12">
                            <StackPanel Margin="10">
                                <TextBlock x:Name="CurrentResourceModeText" Margin="0,0,0,6" FontWeight="Bold" />
                                <RadioButton x:Name="ClassifiedRadio" Content="使用内置月薪喵分类 GIF（推荐：PetAssets\classified_gifs）" GroupName="GifSourceMode" Checked="OnGifSourceModeChanged" />
                                <RadioButton x:Name="BuiltInRadio" Content="使用原始内置 GIF（PetAssets\Gifs）" GroupName="GifSourceMode" Margin="0,6,0,0" Checked="OnGifSourceModeChanged" />
                                <RadioButton x:Name="CustomRadio" Content="使用自定义 GIF 目录" GroupName="GifSourceMode" Margin="0,6,0,0" Checked="OnGifSourceModeChanged" />
                                <DockPanel Margin="18,6,0,0">
                                    <Button x:Name="BrowseGifButton" DockPanel.Dock="Right" Width="92" Content="浏览文件夹" Click="OnBrowseGifDirectoryClick" />
                                    <TextBox x:Name="CustomGifDirectoryBox" Margin="0,0,8,0" />
                                </DockPanel>
                                <StackPanel Orientation="Horizontal" Margin="18,8,0,0">
                                    <Button Content="一键切回内置月薪喵分类 GIF" Margin="0,0,8,0" Click="OnUseBuiltInClick" />
                                    <Button x:Name="OpenGifDirButton" Content="打开当前资源目录" Click="OnOpenCurrentResourceDirectoryClick" />
                                </StackPanel>
                                <TextBlock x:Name="CurrentGifPathText" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#555" />
                                <TextBlock x:Name="GifCountText" TextWrapping="Wrap" Foreground="#555" />
                                <TextBlock x:Name="EnabledGifCountText" TextWrapping="Wrap" Foreground="#555" />
                                <TextBlock x:Name="CategoryCountText" TextWrapping="Wrap" Foreground="#555" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="天气与城市" Margin="0,0,0,12">
                            <StackPanel Margin="10">
                                <CheckBox x:Name="EnableWeatherBox" Content="启用天气" Margin="0,0,0,6" />
                                <CheckBox x:Name="WeatherBubbleBox" Content="天气更新时显示小气泡，并短暂切换天气相关 GIF" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="刷新间隔（分钟）" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="WeatherIntervalBox" Width="60" />
                                    <Button Content="立即刷新天气" Margin="12,0,0,0" Click="OnRefreshWeatherClick" />
                                </StackPanel>
                                <TextBlock x:Name="CurrentWeatherInfoText" TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="省份" Margin="0,3" />
                                    <ComboBox x:Name="ProvinceCombo" Grid.Row="0" Grid.Column="1" DisplayMemberPath="." SelectionChanged="OnProvinceChanged" Margin="0,3" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="城市" Margin="0,3" />
                                    <ComboBox x:Name="CityCombo" Grid.Row="1" Grid.Column="1" DisplayMemberPath="City" SelectedValuePath="City" SelectionChanged="OnCityChanged" Margin="0,3" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="纬度（高级）" Margin="0,3" />
                                    <TextBox x:Name="LatitudeBox" Grid.Row="2" Grid.Column="1" Margin="0,3" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="经度（高级）" Margin="0,3" />
                                    <TextBox x:Name="LongitudeBox" Grid.Row="3" Grid.Column="1" Margin="0,3" />
                                </Grid>
                                <TextBlock Text="选择城市会自动填入经纬度；你也可以手动修改经纬度。保存后会立即刷新天气。"
                                           TextWrapping="Wrap"
                                           Foreground="#666"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="窗口与外观" Margin="0,0,0,12">
                            <StackPanel Margin="10">
                                <CheckBox x:Name="AlwaysOnTopBox" Content="始终置顶" Margin="0,0,0,4" />
                                <CheckBox x:Name="StartupBox" Content="开机启动（当前用户）" Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="缩放比例" Margin="0,6" />
                                    <Slider x:Name="ScaleSlider" Grid.Row="0" Grid.Column="1" Minimum="50" Maximum="200" TickFrequency="5"
                                            IsSnapToTickEnabled="True" SmallChange="5" LargeChange="5" ValueChanged="OnAppearanceSliderChanged" Margin="0,6" />
                                    <TextBlock x:Name="ScaleValueText" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" Margin="8,6,0,6" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="透明度" Margin="0,6" />
                                    <Slider x:Name="OpacitySlider" Grid.Row="1" Grid.Column="1" Minimum="30" Maximum="100" TickFrequency="5"
                                            IsSnapToTickEnabled="True" SmallChange="5" LargeChange="5" ValueChanged="OnAppearanceSliderChanged" Margin="0,6" />
                                    <TextBlock x:Name="OpacityValueText" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" Margin="8,6,0,6" />
                                </Grid>
                                <TextBlock Text="拖动滑块会实时预览；点击取消会恢复打开设置前的缩放和透明度。"
                                           TextWrapping="Wrap"
                                           Foreground="#666"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="时间段设置">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="上班时间" Margin="0,3" />
                                <TextBox x:Name="WorkStartBox" Grid.Row="0" Grid.Column="1" Margin="0,3" />
                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="下班时间" Margin="0,3" />
                                <TextBox x:Name="WorkEndBox" Grid.Row="1" Grid.Column="1" Margin="0,3" />
                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="午休开始" Margin="0,3" />
                                <TextBox x:Name="LunchStartBox" Grid.Row="2" Grid.Column="1" Margin="0,3" />
                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="午休结束" Margin="0,3" />
                                <TextBox x:Name="LunchEndBox" Grid.Row="3" Grid.Column="1" Margin="0,3" />
                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="晚间开始" Margin="0,3" />
                                <TextBox x:Name="EveningStartBox" Grid.Row="4" Grid.Column="1" Margin="0,3" />
                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="睡觉时间" Margin="0,3" />
                                <TextBox x:Name="SleepTimeBox" Grid.Row="5" Grid.Column="1" Margin="0,3" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="资源调试面板">
                <DockPanel Margin="8">
                    <TextBlock DockPanel.Dock="Top"
                               Text="这里显示当前状态、资源来源、分类数量以及候选 GIF 分数 TOP 5，方便后续调整 assets.json 或 assets.tags.override.json。"
                               Margin="0,0,0,8"
                               Foreground="#666" />
                    <TextBox x:Name="DebugTextBox"
                             FontFamily="Consolas"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" />
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
