<Window x:Class="YueXinMiaoPet.Views.MoodWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:YueXinMiaoPet.Controls"
        Title="今日心情"
        Icon="pack://siteoforigin:,,,/Assets/Icons/app.ico"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="今天的你和月薪喵是什么状态？"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#4A2F24" />
            <TextBlock Text="选择心情后，月薪喵会优先从对应分类 GIF 中播放。保存后立即生效。"
                       Margin="0,4,0,0"
                       Foreground="#6F625D" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,14,0">
                <WrapPanel x:Name="MoodCardsPanel" />
            </ScrollViewer>

            <Border Grid.Column="1"
                    Background="#FFF8F2"
                    BorderBrush="#E4C5AA"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="预览"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#4A2F24"
                               Margin="0,0,0,8" />
                    <Border Height="210"
                            Background="#FFFFFFFF"
                            BorderBrush="#EED8C8"
                            BorderThickness="1"
                            CornerRadius="12">
                        <controls:AnimatedGifImage x:Name="PreviewImage"
                                                   Stretch="Uniform"
                                                   Margin="8"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <TextBlock x:Name="SelectedMoodText"
                               Margin="0,12,0,0"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="PreviewInfoText"
                               Margin="0,6,0,0"
                               Foreground="#6F625D"
                               TextWrapping="Wrap" />
                    <TextBlock Text="生效时间"
                               FontWeight="Bold"
                               Margin="0,18,0,6" />
                    <ComboBox x:Name="DurationCombo"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Key" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="保存并生效"
                    Width="110"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="OnSaveClick" />
            <Button Content="取消"
                    Width="78"
                    Height="32"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
