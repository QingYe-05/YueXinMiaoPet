<Window x:Class="YueXinMiaoPet.Views.PlaylistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GIF 轮播设置"
        Icon="pack://siteoforigin:,,,/Assets/Icons/app.ico"
        Width="920"
        Height="650"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="GIF 轮播设置"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#4A2F24" />
            <TextBlock Text="默认按当前心情分类顺序播放；你也可以为某个心情或全局模式多选固定轮播列表。"
                       Margin="0,4,0,0"
                       Foreground="#666"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="全选当前筛选结果" Margin="0,0,8,0" Click="OnSelectAllFilteredClick" />
            <Button Content="清空当前心情选择" Margin="0,0,8,0" Click="OnClearMoodClick" />
            <Button Content="保存当前轮播" Margin="0,0,8,0" Click="OnSaveCurrentClick" />
            <Button Content="恢复默认" Margin="0,0,8,0" Click="OnRestoreDefaultClick" />
            <Button Content="保存并关闭" Width="96" Margin="0,0,8,0" Click="OnSaveAndCloseClick" />
            <Button Content="关闭" Width="72" Click="OnCloseClick" />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FFF8F2"
                    BorderBrush="#E4C5AA"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="心情" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <ComboBox x:Name="MoodCombo"
                              Grid.Row="0"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Key"
                              SelectionChanged="OnFilterChanged"
                              Margin="0,0,12,8" />

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="GIF 来源" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <ComboBox x:Name="SourceCombo"
                              Grid.Row="0"
                              Grid.Column="3"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Key"
                              SelectionChanged="OnFilterChanged"
                              Margin="0,0,12,8" />

                    <TextBlock Grid.Row="0" Grid.Column="4" Text="搜索" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBox x:Name="SearchBox"
                             Grid.Row="0"
                             Grid.Column="5"
                             TextChanged="OnSearchChanged"
                             Margin="0,0,0,8" />

                    <CheckBox x:Name="UseGlobalPlaylistBox"
                              Grid.Row="1"
                              Grid.Column="0"
                              Grid.ColumnSpan="6"
                              Content="启用全局自定义轮播（当前心情没有单独自定义列表时使用；当前心情自定义列表仍然优先）"
                              Checked="OnGlobalPlaylistChanged"
                              Unchecked="OnGlobalPlaylistChanged" />
                </Grid>
            </Border>

            <DataGrid x:Name="GifGrid"
                      Grid.Row="1"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Extended"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      IsReadOnly="False">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="选择"
                                            Width="56"
                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Header="文件名" Width="180" Binding="{Binding FileName}" IsReadOnly="True" />
                    <DataGridTextColumn Header="分类名" Width="120" Binding="{Binding CategoryName}" IsReadOnly="True" />
                    <DataGridTextColumn Header="相对路径" Width="*" Binding="{Binding RelativePath}" IsReadOnly="True" />
                    <DataGridTextColumn Header="enabled" Width="70" Binding="{Binding Enabled}" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock x:Name="StatusText"
                       Grid.Row="2"
                       Margin="0,8,0,0"
                       Foreground="#666"
                       TextWrapping="Wrap" />
        </Grid>
    </DockPanel>
</Window>
