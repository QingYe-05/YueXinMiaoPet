<Window x:Class="YueXinMiaoPet.MainPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:YueXinMiaoPet.Controls"
        Title="月薪喵桌宠"
        Icon="pack://siteoforigin:,,,/Assets/Icons/app.ico"
        Width="220"
        Height="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        MouseMove="OnMouseMove"
        MouseDoubleClick="OnMouseDoubleClick"
        MouseRightButtonUp="OnMouseRightButtonUp"
        StateChanged="OnStateChanged">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="WeatherBadge"
                Grid.Row="0"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                MaxWidth="240"
                Margin="4,0,4,6"
                Padding="10,5"
                CornerRadius="12"
                Background="#DFFFFFFF"
                BorderBrush="#AA7A5A42"
                BorderThickness="1">
            <TextBlock x:Name="WeatherBadgeText"
                       Text="天气不可用"
                       FontSize="12"
                       Foreground="#5B3B2E"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       TextAlignment="Center" />
        </Border>

        <controls:AnimatedGifImage x:Name="PetImage"
                                   Grid.Row="1"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
    </Grid>
</Window>
